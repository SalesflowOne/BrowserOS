{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "apps/server/src/index.ts",
    "apps/server/src/compiled-bootstrap.ts",
    "apps/claw-server/src/main.ts",
    "apps/claw-onboard/src/main.tsx",
    "apps/app/entrypoints/app/main.tsx",
    "apps/app/entrypoints/sidepanel/main.tsx",
    "apps/app/entrypoints/background/index.ts",
    "apps/app/entrypoints/content.ts",
    "apps/app/entrypoints/auth.content/index.ts",
    "apps/app/entrypoints/glow.content/index.ts",
    "apps/app/entrypoints/selection.content.ts",
    "scripts/run-bun-test.ts",
    "scripts/dev/inspect-ui.ts",
    "scripts/patch-windows-exe.ts",
    "apps/eval/scripts/generate-report.ts",
    "apps/eval/scripts/weekly-report.ts",
    "apps/claw-app/entrypoints/newtab/main.tsx",
    "apps/claw-app/entrypoints/background.ts",
    "apps/claw-app/entrypoints/recorder.content.ts",
    "apps/claw-app/onboarding-video/src/index-render.ts"
  ],
  "ignoreDependencies": [
    "tailwind-scrollbar-hide",
    "tw-animate-css",
    "@tailwindcss/typography",
    "pino-pretty",
    "dotenv",
    "picocolors",
    "@browseros/cdp-protocol",
    "@graphql-typed-document-node/core",
    "@remotion/bundler",
    "@remotion/renderer"
  ],
  "ignoreUnresolvedImports": [
    "@/assets/**",
    "@/generated/graphql/**",
    "@/styles/global.css"
  ],
  "ignorePatterns": [
    "**/*.d.ts",
    "**/dist/**",
    "**/node_modules/**",
    "**/*.css",
    "**/.wxt/**",
    "**/.output/**",
    "**/coverage/**",
    "**/tmp/**",
    ".scripts/**",
    "apps/app/schema/**",
    "apps/cli/**",
    "apps/app/assets/**",
    "apps/app/generated/**",
    "apps/app/public/**",
    "apps/eval/data/**",
    "apps/server/src/lib/db/migrations/**",
    "packages/cdp-protocol/src/generated/**",
    ".agents/skills/**",
    ".claude/skills/**"
  ],
  "rules": {
    "unused-files": "warn",
    "unused-exports": "warn",
    "unused-types": "warn",
    "unused-dependencies": "warn",
    "unused-dev-dependencies": "warn",
    "unused-optional-dependencies": "warn",
    "unused-enum-members": "warn",
    "private-type-leaks": "warn",
    "unresolved-imports": "warn",
    "unlisted-dependencies": "warn",
    "circular-dependencies": "warn",
    "unused-class-members": "off",
    "duplicate-exports": "off",
    "boundary-violation": "error"
  },
  "boundaries": {
    "zones": [
      {
        "name": "claw-app-extension",
        "patterns": [
          "apps/claw-app/entrypoints/**",
          "apps/claw-app/components/**",
          "apps/claw-app/screens/**",
          "apps/claw-app/modules/**"
        ]
      },
      {
        "name": "claw-app-video",
        "patterns": ["apps/claw-app/onboarding-video/**"]
      }
    ],
    "rules": [
      {
        "from": "claw-app-extension",
        "allow": []
      },
      {
        "from": "claw-app-video",
        "allow": ["claw-app-extension"]
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/*.spec.tsx",
        "**/tests/**",
        "**/*.config.ts",
        "**/codegen.ts"
      ],
      "rules": {
        "unused-exports": "off",
        "unused-files": "off"
      }
    },
    {
      "files": [
        "apps/app/components/ui/**",
        "apps/app/components/ai-elements/**"
      ],
      "rules": {
        "unused-exports": "off",
        "unused-files": "off",
        "unused-types": "off",
        "private-type-leaks": "off"
      }
    }
  ]
}

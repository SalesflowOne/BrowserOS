# OWeb Browser — agent platform development defaults
# Copy to packages/browseros-agent/.env.development in the fork.

# --- app (browser extension / new-tab UI) ---
VITE_PRODUCT_NAME=OWeb Browser
VITE_COMPANY_NAME=OWeb
VITE_AUTH_URL=https://oweb.one/auth/browser
VITE_API_BASE_URL=https://oweb.one/api/extension/v1
VITE_LOCAL_API_BASE_URL=http://localhost:8080/api/extension/v1
VITE_ACCENT_COLOR=#22D3EE
VITE_DOCS_URL=https://oweb.one/docs
VITE_HIDE_BYOK=true

# --- server (Bun agent loop) ---
# Default LLM provider: OWeb OpenAI-compatible proxy
OWEB_DEFAULT_PROVIDER=oweb
OWEB_API_BASE_URL=https://oweb.one/api/extension/v1
OWEB_LOCAL_API_BASE_URL=http://localhost:8080/api/extension/v1

# --- dev-tools ---
# Point at a locally built OWeb Browser binary when testing CDP integration
# BROWSEROS_BINARY=/Applications/OWeb Browser.app/Contents/MacOS/OWeb Browser

{
  // Two-task subset for quick end-to-end Langfuse smoke tests.
  "name": "agisdk-mini",

  // Path to the JSONL dataset, relative to this config file.
  "dataset": "../datasets/agisdk-real-mini.jsonl",

  // eval2 supports OpenAI only in v1.
  "provider": "openai",

  // OpenAI model id. Examples: gpt-4.1, gpt-4.1-mini.
  "model": "gpt-4.1",

  // Name of the env var that holds the OpenAI API key.
  "apiKeyEnv": "OPENAI_API_KEY",

  // Path to the BrowserOS binary that spawns Chrome with CDP enabled.
  "browserosBinary": "/Applications/BrowserOS.app/Contents/MacOS/BrowserOS",

  // Port allocation for the single worker. Fixed in v1.
  "ports": {
    "cdp": 9010,
    "server": 9110,
    "extension": 9310
  },

  // Maximum wall-clock time per task, in milliseconds.
  "timeoutMs": 600000,

  // Langfuse credentials come from env: LANGFUSE_PUBLIC_KEY, LANGFUSE_SECRET_KEY,
  // and optional LANGFUSE_BASE_URL (defaults to https://cloud.langfuse.com).
  // screenshotMode: "all" | "mutating-only" | "never".
  //   all            - every tool call gets a PNG span attached
  //   mutating-only  - only click/fill/navigate/scroll/press_key/select_option/drag/type_at
  //   never          - disable screenshots; LLM-call traces only
  "langfuse": {
    "enabled": true,
    "sessionPrefix": "agisdk",
    "screenshotMode": "all"
  }
}

# Generated by bun run env:examples. Do not edit by hand.
# This is the production env example for the BrowserOS monorepo root.
# Copy it to .env.production; real .env.production files are gitignored.

# --- claw ---

# Claw server PostHog project write key.
CLAW_POSTHOG_KEY=

# --- server ---

# BrowserOS server config URL required by production builds.
BROWSEROS_CONFIG_URL=https://llm.browseros.com/api/browseros-server/config

# Server telemetry key; CLI release builds read the same key.
POSTHOG_API_KEY=

# Server Sentry DSN.
SENTRY_DSN=

# Node environment for server and build scripts.
NODE_ENV=production

# Server log level.
LOG_LEVEL=info

# --- build ---

# Agent runner JWT secret inlined into server builds when present.
AGENT_RUNNER_JWT_SECRET=

# --- upload ---

# R2 account ID for production artifact uploads.
R2_ACCOUNT_ID=

# R2 access key ID for production artifact uploads.
R2_ACCESS_KEY_ID=

# R2 secret access key for production artifact uploads.
R2_SECRET_ACCESS_KEY=

# R2 bucket for production artifact uploads.
R2_BUCKET=browseros

# --- sign ---

# BrowserOS build eSigner username for Windows production signing.
ESIGNER_USERNAME=

# BrowserOS build eSigner password for Windows production signing.
ESIGNER_PASSWORD=

# BrowserOS build eSigner TOTP secret for Windows production signing.
ESIGNER_TOTP_SECRET=

# BrowserOS build eSigner credential ID for Windows production signing.
ESIGNER_CREDENTIAL_ID=
